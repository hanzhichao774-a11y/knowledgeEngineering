# AgentOS API
PORT=3011

# Runtime root. Defaults to AgentOS/runtime when omitted.
AGENTOS_RUNTIME_ROOT=/absolute/path/to/AgentOS/runtime

# Optional one-time legacy import source. Used only when local runtime is empty.
AGENTOS_LEGACY_GRAPHIFY_WORKSPACE_PATH=/absolute/path/to/graphify-workspace

# Graphify build adapter
# Configure either GRAPHIFY_REPO_PATH or AGENTOS_GRAPHIFY_BUILD_COMMAND.
GRAPHIFY_REPO_PATH=/absolute/path/to/graphify-v3
GRAPHIFY_PYTHON_BIN=/usr/bin/python3

# Alternative build entrypoint. Runs inside runtime/projects/{projectId}.
# Example: AGENTOS_GRAPHIFY_BUILD_COMMAND=python /absolute/path/to/custom_build.py
AGENTOS_GRAPHIFY_BUILD_COMMAND=
